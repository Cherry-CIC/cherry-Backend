{
  "name": "cherry-help",
  "version": "0.1.0",
  "description": "Internal Slack help bot for cherry volunteers.",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "main": "dist/src/app.js",
  "scripts": {
    "build": "tsc",
    "build-index": "ts-node scripts/build-index.ts",
    "dev": "ts-node src/app.ts",
    "start": "node dist/src/app.js",
    "test": "jest --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@notionhq/client": "^2.2.15",
    "@slack/bolt": "^3.21.2",
    "dotenv": "^16.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.32",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
